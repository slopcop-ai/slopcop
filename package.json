{
	"name": "slopcop",
	"version": "0.1.0",
	"description": "Zod-first TypeScript library for type-safe, maintainable LLM prompt engineering",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./mcp": {
			"types": "./dist/mcp/index.d.ts",
			"import": "./dist/mcp/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit -p tsconfig.check.json",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"ci": "bun run check && bun run lint && bun run test"
	},
	"peerDependencies": {
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.3.9",
		"lefthook": "^1.9.0",
		"typescript": "^5.6.0",
		"zod": "^4.3.6"
	},
	"license": "AGPL-3.0-only",
	"homepage": "https://slopcop.ai",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/slopcop-ai/slopcop.git"
	},
	"keywords": [
		"llm",
		"prompt-engineering",
		"typescript",
		"zod",
		"type-safe",
		"mcp",
		"ai",
		"slopcop"
	],
	"trustedDependencies": ["@biomejs/biome"]
}
