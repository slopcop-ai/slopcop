{
	"name": "strongly-skilled",
	"version": "0.1.0",
	"description": "Zod-first TypeScript library for type-safe, maintainable LLM prompt engineering",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./mcp": {
			"types": "./dist/mcp/index.d.ts",
			"import": "./dist/mcp/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"check": "tsc --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"ci": "bun run check && bun run lint && bun run test"
	},
	"peerDependencies": {
		"zod": "^3.22.0",
		"zod-to-json-schema": "^3.22.0"
	},
	"peerDependenciesMeta": {
		"zod-to-json-schema": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"lefthook": "^1.9.0",
		"typescript": "^5.6.0",
		"zod": "^3.24.0",
		"zod-to-json-schema": "^3.25.1"
	},
	"license": "MIT",
	"trustedDependencies": ["@biomejs/biome"]
}
