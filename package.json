{
  "name": "strongly-skilled",
  "version": "0.1.0",
  "description": "Zod-first TypeScript library for type-safe, maintainable LLM prompt engineering",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest"
  },
  "peerDependencies": {
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod-to-json-schema": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "license": "MIT"
}
